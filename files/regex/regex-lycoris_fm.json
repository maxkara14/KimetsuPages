div>\n        <div style=\"font-style: italic; color: #fff; margin-bottom: 4px;\">$1</div>\n        <div style=\"font-size: 0.85em; opacity: 0.8;\">News: $2</div>\n    </div>\n\n    <div style=\"display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-bottom: 15px;\">\n        <div style=\"background: rgba(255, 10, 67, 0.05); border: 1px solid #3d000f; padding: 8px; border-radius: 4px;\">\n            <div style=\"color: #ff4d6d; font-size: 0.7em; font-weight: bold; margin-bottom: 4px;\">🤡 LOL</div>\n            <div style=\"font-size: 0.85em;\">\"$3\"</div>\n        </div>\n        <div style=\"background: rgba(255, 10, 67, 0.05); border: 1px solid #3d000f; padding: 8px; border-radius: 4px;\">\n            <div style=\"color: #ff4d6d; font-size: 0.7em; font-weight: bold; margin-bottom: 4px;\">🧠 FACT</div>\n            <div style=\"font-size: 0.85em;\">\"$4\"</div>\n        </div>\n    </div>\n\n    <div style=\"background: #000; border: 1px solid #ff0a43; padding: 10px; border-radius: 4px; display: flex; align-items: center; gap: 12px; position: relative; overflow: hidden;\">\n        <div style=\"position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: linear-gradient(90deg, rgba(255,10,67,0.08) 0%, rgba(0,0,0,0) 60%); z-index: 0;\"></div>\n        \n        <div style=\"z-index: 1; font-size: 1.4em; animation: blinkLive 4s infinite;\">💿</div>\n        \n        <div style=\"z-index: 1; display: flex; flex-direction: column; width: 100%;\">\n            <span style=\"font-size: 0.65em; color: #ff4d6d; letter-spacing: 2px;\">NOW PLAYING</span>\n            <a href=\"https://www.youtube.com/results?search_query=$5\" target=\"_blank\" style=\"color: #fff; text-decoration: none; font-weight: bold; font-family: monospace; font-size: 0.95em; text-shadow: 0 0 5px rgba(255,10,67,0.5);\">\n                $5 ↗\n            </a>\n        </div>\n\n        <div style=\"z-index: 1; display: flex; gap: 3px; align-items: flex-end; height: 15px;\">\n   